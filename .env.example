# Open Research Agent v0.1 configuration
ORA_ENVIRONMENT=development
ORA_LOG_LEVEL=INFO

# Runtime paths
ORA_RUNS_DIR=outputs/runs
ORA_ARTIFACTS_DIR=outputs/artifacts

# Models (currently optional in deterministic MVP flow)
ORA_DEFAULT_MODEL=gpt-4o-mini
ORA_PLANNER_MODEL=gpt-4o-mini
ORA_ANALYSIS_MODEL=gpt-4o-mini
ORA_OPENAI_API_KEY=
ORA_ANTHROPIC_API_KEY=

# Search/fetch controls
ORA_SEARCH_PROVIDER=duckduckgo_html
ORA_SEARCH_ENDPOINT=https://duckduckgo.com/html/
ORA_SEARCH_API_KEY=
ORA_REQUEST_TIMEOUT_SECONDS=10
ORA_REQUEST_RETRIES=2
ORA_USER_AGENT=open-research-agent/0.1 (+https://example.local)
ORA_MAX_SOURCES_PER_RUN=8
ORA_MAX_FETCH_PER_RUN=6

# API binding
ORA_API_HOST=127.0.0.1
ORA_API_PORT=8000
