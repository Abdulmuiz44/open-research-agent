# Open Research Agent configuration
ORA_ENVIRONMENT=development
ORA_LOG_LEVEL=INFO
ORA_OPENAI_API_KEY=
ORA_SEARCH_API_KEY=
ORA_DEFAULT_MODEL=gpt-4o-mini
ORA_PLANNER_MODEL=gpt-4o-mini
ORA_ANALYSIS_MODEL=gpt-4o-mini
ORA_RUNS_DIR=outputs/runs
ORA_ARTIFACTS_DIR=outputs/artifacts
ORA_DATABASE_URL=duckdb:///outputs/ora.duckdb
ORA_MAX_SOURCES=10
ORA_REQUEST_TIMEOUT_SECONDS=20
ORA_ENABLE_BROWSER_FALLBACK=true
